
{
  "entities": {
    "Movement": {
      "title": "Movement",
      "description": "Representa uma movimentação financeira (entrada ou saída) no sistema de caixa.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["PIX", "CREDITO", "DEBITO", "DELIVERY", "DINHEIRO", "WITHDRAWAL", "DESPESAS"]
        },
        "value": { "type": "number" },
        "description": { "type": "string" },
        "observation": { "type": "string" },
        "timestamp": { "type": "number" },
        "aiCategory": { "type": "string" },
        "aiSuggestions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["type", "value", "description", "timestamp"]
    },
    "BrandSettings": {
      "title": "Brand Settings",
      "description": "Configurações de identidade visual e contato da empresa.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "whatsapp": { "type": "string" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Produto disponível no cardápio digital.",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "preco": { "type": "number" },
        "imagem": { "type": "string" },
        "descricao": { "type": "string" },
        "ativo": { "type": "boolean" },
        "categoria": { "type": "string" }
      },
      "required": ["nome", "preco", "ativo"]
    },
    "Order": {
      "title": "Order",
      "description": "Pedido realizado pelo cliente.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "clienteNome": { "type": "string" },
        "clienteTelefone": { "type": "string" },
        "itens": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "nome": { "type": "string" },
              "preco": { "type": "number" },
              "qtd": { "type": "number" }
            }
          } 
        },
        "total": { "type": "number" },
        "status": { 
          "type": "string",
          "enum": ["novo", "preparando", "saiu_entrega", "entregue", "cancelado"]
        },
        "pagamento": { "type": "string" },
        "tipoEntrega": { "type": "string" },
        "endereco": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["clienteNome", "itens", "total", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/movements/{movementId}": {
      "schema": "Movement",
      "description": "Coleção de todas as transações financeiras realizadas."
    },
    "/settings/brand": {
      "schema": "BrandSettings",
      "description": "Documento único que armazena o nome, logo e contato da empresa."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Produtos do cardápio."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Pedidos realizados via delivery."
    }
  }
}
